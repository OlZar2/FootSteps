@page "/email-confirmation/user-not-found"
@{
    Layout = "/Pages/Shared/_EmailConfirmationLayout.cshtml";
    Response.StatusCode = 404;
    ViewData["Title"] = "Не удалось подтвердить почту";
    ViewData["Status"] = "Ошибка";
    ViewData["Action"] = "Вернуться в приложение";
    ViewData["IsSuccess"] = false;
}

@section Mark {
    <svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 8v5"></path>
        <path d="M12 17h.01"></path>
        <path d="M10.3 4.2 2.5 18a2 2 0 0 0 1.7 3h15.6a2 2 0 0 0 1.7-3L13.7 4.2a2 2 0 0 0-3.4 0Z"></path>
    </svg>
}

<h1 id="email-confirmation-title">Ссылка не сработала</h1>
<p>Мы не нашли пользователя для подтверждения почты. Проверьте письмо или запросите новую ссылку.</p>
