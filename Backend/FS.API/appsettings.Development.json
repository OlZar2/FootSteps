{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "S3StorageConfiguration": {
    "ServiceURL": "https://s3.yandexcloud.net",
    "BucketName": "fs-bucket",
    "Region": "ru-central1",
    "ImagesBucketUrl": "https://storage.yandexcloud.net/fs-bucket"
  },
  "JwtOptions": {
    "ExpiresHours": "240"
  },
  "EmailConfirmationOptions": {
    "ConfirmationUrlTemplate": "http://localhost:5000/api/auth/confirm-email?userId={userId}&token={token}"
  },
  "SmtpEmailOptions": {
    "Host": "",
    "Port": 587,
    "UserName": "",
    "Password": "",
    "FromEmail": "",
    "FromName": "FootSteps",
    "UseSsl": false
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Port=5433;Database=FootSteps;User Id=postgres;Password=postgres"
  },
  "AllowedHosts": "*"
}
