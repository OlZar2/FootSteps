{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "S3StorageConfiguration": {
    "ServiceURL": "https://s3.yandexcloud.net",
    "BucketName": "fs-bucket",
    "Region": "ru-central1",
    "ImagesBucketUrl": "https://storage.yandexcloud.net/fs-bucket"
  },
  "JwtOptions": {
    "ExpiresHours": "240"
  },
  "EmailConfirmationOptions": {
    "ConfirmationUrlTemplate": "http://161.104.52.29:8080/api/auth/confirm-email?userId={userId}&token={token}"
  },
  "SmtpEmailOptions": {
    "Host": "smtp.mail.selcloud.ru",
    "Port": 1127,
    "UserName": "9651",
    "FromEmail": "noreply@txshare.ru",
    "FromName": "По следам",
    "UseSsl": true
  },
  "RabbitMqOptions": {
    "Uri": "amqp://guest:guest@localhost:5672/"
  },
  "ImageEmbeddingRabbitOptions": {
    "ExchangeName": "img.topic",
    "ResponseKey": "image.embed.response",
    "RequestKey": "image.embed.request",
    "ResponseQueue": "embeddings.response.q",
    "SearchResponseKey": "image.search.response",
    "SearchRequestKey": "image.search.request",
    "SearchResponseQueue": "search.response.q"
  },
  "ImagesOptions": {
    "AllowedImageExtensions": [
      "jpg",
      "jpeg",
      "png",
      "gif",
      "webp",
      "avif",
      "heic",
      "heif"
    ],
    "AllowedContentTypes": [
      "image/jpeg",
      "image/png",
      "image/gif",
      "image/webp",
      "image/avif",
      "image/heic",
      "image/heif",
      "image/heic-sequence",
      "image/heif-sequence"
    ],
    "MaxByteSize": 5242880
  },
  "AdminAnimalAnnouncementListOptions": {
    "MinPageSize": 10,
    "MaxPageSize": 30,
    "DefaultPageSize": 20
  },
  "OltpOptions":{
    "Uri": "http://localhost:4317"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.Grafana.Loki" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "GrafanaLoki",
        "Args": {
          "uri": "http://localhost:3100",
          "labels": [
            { "key": "app", "value": "myapp" },
            { "key": "environment", "value": "dev" }
          ],
          "propertiesAsLabels": [ ]
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
