<!doctype html>
<html lang="ru">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Подтверждение почты</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            background: #f2f2f3;
            color: #151116;
            font-family: Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        }

        .screen {
            width: 100%;
            padding: 24px 12px;
            background: #f2f2f3;
        }

        .panel {
            width: 100%;
            max-width: 390px;
            margin: 0 auto;
            overflow: hidden;
            background: #ffffff;
            border: 1px solid #ebe8ea;
            border-radius: 28px;
            box-shadow: 0 22px 70px rgba(42, 6, 24, .08);
        }

        .content {
            padding: 34px 20px;
            text-align: center;
        }

        h1 {
            margin: 0;
            color: #151116;
            font-size: 26px;
            line-height: 1.15;
            font-weight: 800;
            letter-spacing: 0;
        }

        p {
            max-width: 300px;
            margin: 12px auto 0;
            color: #7c747b;
            font-size: 15px;
            line-height: 1.45;
        }

        .button {
            display: inline-block;
            margin-top: 24px;
            padding: 13px 22px;
            border-radius: 999px;
            background: #151116;
            color: #ffffff !important;
            font-size: 15px;
            font-weight: 700;
            line-height: 1;
            text-decoration: none !important;
        }

        .fallback {
            word-break: break-word;
            font-size: 12px;
            line-height: 1.45;
        }
    </style>
</head>
<body>
<main class="screen">
    <section class="panel" aria-labelledby="email-confirmation-title">
        <div class="content">
            <h1 id="email-confirmation-title">Подтвердите почту</h1>
            <p>Нажмите кнопку, чтобы завершить регистрацию и войти в аккаунт FootSteps.</p>
            <a class="button"
               href="@Model.ConfirmationUrl"
               style="display: inline-block; margin-top: 24px; padding: 13px 22px; border-radius: 999px; background: #151116; color: #ffffff !important; font-size: 15px; font-weight: 700; line-height: 1; text-decoration: none !important;">
                <span style="color: #ffffff !important; text-decoration: none !important;">Подтвердить почту</span>
            </a>
            <p class="fallback">Если кнопка не открывается, скопируйте ссылку: @Model.ConfirmationUrl</p>
        </div>
    </section>
</main>
</body>
</html>

@code {
    [Parameter]
    [EditorRequired]
    public required EmailConfirmationTemplateModel Model { get; set; }
}
