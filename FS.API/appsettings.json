{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "S3StorageConfiguration": {
    "ServiceURL": "https://s3.yandexcloud.net",
    "BucketName": "fs-dev-bucket",
    "Region": "ru-central1",
    "ImagesBucketUrl": "https://storage.yandexcloud.net/fs-bucket"
  },
  "JwtOptions": {
    "ExpiresHours": "240"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Port=5432;Database=FootSteps;User Id=postgres;Password=12345"
  },
  "RabbitMqOptions": {
    "Uri": "amqp://guest:guest@localhost:5672/"
  },
  "ImageEmbeddingRabbitOptions": {
    "ExchangeName": "img.topic",
    "ResponseKey": "image.embed.response",
    "RequestKey": "image.embed.request",
    "ResponseQueue": "embeddings.response.q",
    "SearchResponseKey": "image.search.response",
    "SearchRequestKey": "image.search.request",
    "SearchResponseQueue": "search.response.q"
  },
  "ImagesOptions": {
    "AllowedImageExtensions": [
      "jpg",
      "jpeg",
      "png",
      "gif",
      "webp",
      "avif",
      "heic",
      "heif"
    ],
    "AllowedContentTypes": [
      "image/jpeg",
      "image/png",
      "image/gif",
      "image/webp",
      "image/avif",
      "image/heic",
      "image/heif",
      "image/heic-sequence",
      "image/heif-sequence"
    ],
    "MaxByteSize": 5242880
  },
  "AllowedHosts": "*"
}
